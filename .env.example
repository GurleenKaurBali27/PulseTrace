# ============================================================================
# API Failure Visualizer - Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment
# This single .env file is shared across all three services
#
# Services read from this root-level .env file and fall back to defaults
# ============================================================================

# ============================================================================
# ENVIRONMENT & DEPLOYMENT
# ============================================================================
# development | staging | production
NODE_ENV=development

# Deployment platform: local | vercel | render | heroku | other
DEPLOYMENT_PLATFORM=local

# ============================================================================
# SERVER CONFIGURATION (Backend - Port 5000)
# ============================================================================
# Express server port
SERVER_PORT=5000

# Database connection
# Local development: uses SQLite (file-based, no connection string needed)
# Production: use PostgreSQL connection string
DATABASE_URL=sqlite://./database.db
# Example PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/api_visualizer

# Log level: error | warn | info | debug | trace
LOG_LEVEL=info

# Enable request body logging (caution in production)
LOG_REQUEST_BODY=false

# CORS allowed origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4000

# ============================================================================
# CLIENT CONFIGURATION (Frontend - Port 3000/5173)
# ============================================================================
# Vite dev server port
CLIENT_PORT=5173

# API endpoint for React client to call
VITE_API_URL=http://localhost:5000

# Optional: analytics service endpoint
VITE_ANALYTICS_URL=http://localhost:5000

# ============================================================================
# TEST API CONFIGURATION (Port 4000)
# ============================================================================
# Test API server port
TESTAPI_PORT=4000

# Service name identifier for tracker
TRACKER_SERVICE_NAME=test-api

# Server URL for test API to send logs to
TRACKER_URL=http://localhost:5000

# Enable detailed request logging in test API
TESTAPI_LOG_VERBOSE=false

# ============================================================================
# TRACKER MIDDLEWARE CONFIGURATION
# ============================================================================
# Shared across all services using the tracker middleware

# URL where tracker sends logs
TRACKER_SERVER_URL=http://localhost:5000

# Service name for identification
SERVICE_NAME=default-service

# ============================================================================
# SECURITY & AUTHENTICATION (for future use)
# ============================================================================
# API key for secure endpoints (optional)
# API_KEY=your_secret_key_here

# JWT secret for authentication (optional, future feature)
# JWT_SECRET=your_jwt_secret_here

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features for gradual rollout

# Enable real-time WebSocket updates
FEATURE_REALTIME=true

# Enable alerts system
FEATURE_ALERTS=true

# Enable multi-service monitoring
FEATURE_MULTISERVICE=true

# Enable analytics dashboard
FEATURE_ANALYTICS=true

# ============================================================================
# THIRD-PARTY INTEGRATIONS (for future use)
# ============================================================================
# Slack webhook for critical alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email service for alerts
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your_sendgrid_key

# PagerDuty integration
# PAGERDUTY_API_KEY=your_pagerduty_key

# ============================================================================
# PERFORMANCE & CACHING
# ============================================================================
# Cache statistics (seconds)
STATS_CACHE_TTL=300

# Max concurrent connections
MAX_CONNECTIONS=100

# Request timeout (milliseconds)
REQUEST_TIMEOUT=30000

# ============================================================================
# MONITORING & METRICS
# ============================================================================
# Enable Prometheus metrics (future feature)
# METRICS_ENABLED=true

# Send metrics to external service
# METRICS_ENDPOINT=https://metrics.example.com

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Seed database with demo data on startup
SEED_DEMO_DATA=false

# Mock external services (useful for testing)
MOCK_EXTERNAL_SERVICES=false

# Pretty print JSON responses
JSON_PRETTY_PRINT=true

# ============================================================================
# NOTES
# ============================================================================
# - Remove this file from git (.env is in .gitignore)
# - Never commit sensitive credentials
# - Use .env.production for production values
# - Each service will read from this root .env file
# - Services can override via environment variables: NODE_ENV=production npm start
# - On deployment platforms (Vercel/Render), set these vars in platform dashboard
